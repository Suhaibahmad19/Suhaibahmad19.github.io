---
interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Suhaib Ahmad — Full-stack software engineer building AI-powered products with Django, FastAPI, LangChain, and RAG pipelines.',
  canonicalURL = Astro.url.href,
  ogImage = '/og-image.png',
} = Astro.props;

const siteTitle = title === 'Home' ? 'Suhaib Ahmad — Software Engineer' : `${title} | Suhaib Ahmad`;

import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={description} />
    <meta name="author" content="Suhaib Ahmad" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Person Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Suhaib Ahmad",
      "url": "https://suhaibahmad19.github.io",
      "jobTitle": "Software Engineer",
      "worksFor": {
        "@type": "Organization",
        "name": "WAMO Labs"
      },
      "sameAs": [
        "https://linkedin.com/in/suhaibahmad42",
        "https://github.com/Suhaibahmad19"
      ],
      "email": "suhaibraza42@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Lahore",
        "addressCountry": "PK"
      }
    })} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme toggle script -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </body>
</html>
