---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
---

<BaseLayout title="Experience" description="Professional experience and career timeline of Suhaib Ahmad.">
  <ExperienceTimeline />

  <!-- Resume CTA -->
  <section class="pb-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="glass rounded-2xl p-8 max-w-lg mx-auto">
        <h3 class="text-xl font-bold mb-3">Interested in my background?</h3>
        <p class="text-dark-400 text-sm mb-6">Let's connect and discuss how I can contribute to your team.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl gradient-bg text-white font-semibold shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40 hover:scale-105 transition-all duration-200"
          >
            Get in Touch
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/resume.pdf"
            download
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-primary-500/40 text-primary-300 font-semibold hover:bg-primary-500/10 hover:border-primary-500/60 hover:scale-105 transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
