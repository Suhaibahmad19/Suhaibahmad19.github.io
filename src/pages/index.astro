---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import TechStackSection from '../components/TechStackSection.astro';
import FeaturedProjects from '../components/FeaturedProjects.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import ContactSection from '../components/ContactSection.astro';
---

<BaseLayout title="Home">
  <HeroSection />

  <div class="section-divider max-w-6xl mx-auto"></div>

  <TechStackSection />

  <div class="section-divider max-w-6xl mx-auto"></div>

  <FeaturedProjects />

  <div class="section-divider max-w-6xl mx-auto"></div>

  <ExperienceTimeline limit={2} />

  <div class="section-divider max-w-6xl mx-auto"></div>

  <ContactSection />
</BaseLayout>
