---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Suhaib Ahmad for collaboration, opportunities, or just to say hello.">
  <section class="py-12 sm:py-16 relative overflow-hidden">
    <!-- Background -->
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-primary-600/15 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/3 w-64 h-64 bg-accent-500/10 rounded-full blur-[80px] pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl font-bold animate-fade-in-up">
          Get in <span class="gradient-text">Touch</span>
        </h1>
        <p class="mt-4 text-dark-400 max-w-xl mx-auto animate-fade-in-up animate-delay-100">
          Have a project in mind or want to collaborate? I'd love to hear from you.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="max-w-xl mx-auto animate-fade-in-up animate-delay-200">
        <div class="space-y-4">
          <a href="mailto:suhaibraza42@gmail.com" class="glass rounded-xl p-4 flex items-center gap-4 glow-hover block">
            <div class="p-3 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500 uppercase tracking-wider">Email</p>
              <p class="text-dark-200 font-medium">suhaibraza42@gmail.com</p>
            </div>
          </a>

          <a href="tel:+923124381762" class="glass rounded-xl p-4 flex items-center gap-4 glow-hover block">
            <div class="p-3 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500 uppercase tracking-wider">Phone</p>
              <p class="text-dark-200 font-medium">+92 312 438 1762</p>
            </div>
          </a>

          <a href="https://wa.me/923124381762" target="_blank" rel="noopener noreferrer" class="glass rounded-xl p-4 flex items-center gap-4 glow-hover block">
            <div class="p-3 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500 uppercase tracking-wider">WhatsApp</p>
              <p class="text-dark-200 font-medium">+92 312 438 1762</p>
            </div>
          </a>

          <div class="glass rounded-xl p-4 flex items-center gap-4">
            <div class="p-3 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500 uppercase tracking-wider">Location</p>
              <p class="text-dark-200 font-medium">Lahore, Pakistan</p>
            </div>
          </div>
        </div>

        <!-- Social Links -->
        <div class="mt-8">
          <h3 class="text-sm font-semibold text-dark-300 uppercase tracking-wider mb-4">Connect Online</h3>
          <div class="flex gap-3">
            <a
              href="https://github.com/Suhaibahmad19"
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 rounded-xl glass glow-hover text-dark-400 hover:text-primary-400 transition-colors"
              aria-label="GitHub"
            >
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
