---
import BaseLayout from '../layouts/BaseLayout.astro';
import { techStack } from '../data/techstack';
---

<BaseLayout title="About" description="Learn more about Suhaib Ahmad — a full-stack software engineer specializing in AI-powered products.">
  <!-- Hero -->
  <section class="relative py-12 sm:py-16 overflow-hidden">
    <div class="absolute top-0 right-1/4 w-80 h-80 bg-primary-600/15 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold animate-fade-in-up">
          About <span class="gradient-text">Me</span>
        </h1>

        <div class="mt-8 space-y-6 text-dark-300 leading-relaxed animate-fade-in-up animate-delay-100">
          <p class="text-lg">
            Hi! I'm <span class="text-dark-100 font-semibold">Suhaib Ahmad</span>, a full-stack software engineer based in
            <span class="text-dark-100">Lahore, Pakistan</span>. I have 1+ year of professional experience building
            AI-powered products using Django, FastAPI, LangChain, and RAG pipelines.
          </p>

          <p>
            I'm passionate about accessible technology and currently developing an
            <span class="text-primary-400">AI-powered companion app for the hearing impaired</span>.
            I believe technology should be a bridge, not a barrier.
          </p>

          <p>
            When I'm not coding, I enjoy exploring new AI research papers, mentoring junior developers,
            and contributing to open-source projects. I've mentored 10+ fresh graduate engineers and
            led internal workshops on AI tooling at WAMO Labs.
          </p>
        </div>

        <!-- Quick Info -->
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4 animate-fade-in-up animate-delay-200">
          <div class="glass rounded-xl p-4 flex items-center gap-3">
            <div class="p-2 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500">Location</p>
              <p class="text-sm font-medium text-dark-200">Lahore, Pakistan</p>
            </div>
          </div>

          <div class="glass rounded-xl p-4 flex items-center gap-3">
            <div class="p-2 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500">Current Role</p>
              <p class="text-sm font-medium text-dark-200">Assoc. SE @ WAMO Labs</p>
            </div>
          </div>

          <div class="glass rounded-xl p-4 flex items-center gap-3">
            <div class="p-2 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500">Email</p>
              <p class="text-sm font-medium text-dark-200">suhaibraza42@gmail.com</p>
            </div>
          </div>

          <div class="glass rounded-xl p-4 flex items-center gap-3">
            <div class="p-2 rounded-lg gradient-bg">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <p class="text-xs text-dark-500">Focus</p>
              <p class="text-sm font-medium text-dark-200">AI / ML & Full-Stack</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider max-w-6xl mx-auto"></div>

  <!-- Skills Detail -->
  <section class="py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold mb-12 text-center">
        Skills & <span class="gradient-text">Technologies</span>
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {techStack.map((category) => (
          <div class="glass rounded-2xl p-6 glow-hover">
            <h3 class="font-semibold text-dark-100 mb-4">{category.name}</h3>
            <div class="flex flex-wrap gap-2">
              {category.items.map((item) => (
                <span class="px-3 py-1.5 text-sm rounded-lg bg-primary-500/10 text-primary-300 border border-primary-500/20">
                  {item}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
