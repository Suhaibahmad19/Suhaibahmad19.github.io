---
import { experiences } from '../data/experience';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const items = limit ? experiences.slice(0, limit) : experiences;
---

<section id="experience-timeline" class="py-12 sm:py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-bold">
        Work <span class="gradient-text">Experience</span>
      </h2>
      <p class="mt-4 text-dark-400 max-w-xl mx-auto">
        Professional journey and key accomplishments.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative max-w-2xl mx-auto">
      <!-- Vertical Line -->
      <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-primary-500 via-accent-500 to-transparent"></div>

      <div class="flex flex-col gap-12">
        {items.map((exp, i) => (
          <div class={`relative pl-12 sm:pl-16 animate-fade-in-up animate-delay-${(i + 1) * 100}`}>
            <!-- Dot -->
            <div class="absolute left-2.5 sm:left-4.5 top-1 w-3 h-3 rounded-full gradient-bg ring-4 ring-dark-950"></div>

            <!-- Card -->
            <div class="glass rounded-2xl p-6">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-lg font-bold text-dark-100">{exp.role}</h3>
                  <p class="text-primary-400 font-medium text-sm">{exp.company}</p>
                </div>
                <span class="text-xs font-medium text-dark-500 bg-dark-800/50 px-3 py-1 rounded-full whitespace-nowrap">
                  {exp.period}
                </span>
              </div>

              <ul class="space-y-2">
                {exp.achievements.map((ach) => (
                  <li class="flex items-start gap-2 text-sm text-dark-300">
                    <svg class="w-4 h-4 text-primary-400 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {ach}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
