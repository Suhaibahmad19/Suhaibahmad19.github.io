---
---

<section id="contact-cta" class="py-12 sm:py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative glass rounded-3xl p-8 sm:p-12 lg:p-16 text-center overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary-600/20 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent-500/15 rounded-full blur-[60px] pointer-events-none"></div>

      <div class="relative">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Let's <span class="gradient-text">Work Together</span>
        </h2>
        <p class="text-dark-400 max-w-lg mx-auto mb-8 text-lg">
          I'm always open to discussing new projects, opportunities, and ideas.
          Feel free to reach out!
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/contact"
            id="cta-contact"
            class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl gradient-bg text-white font-semibold shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40 hover:scale-105 transition-all duration-200"
          >
            Get in Touch
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="https://linkedin.com/in/suhaibahmad42"
            target="_blank"
            rel="noopener noreferrer"
            id="cta-linkedin"
            class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-dark-700 text-dark-200 font-semibold hover:border-primary-500/50 hover:text-white hover:bg-white/5 transition-all duration-200"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
