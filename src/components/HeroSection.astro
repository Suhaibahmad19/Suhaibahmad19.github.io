---
---

<section id="hero" class="relative overflow-hidden py-12 sm:py-16 lg:py-20">
  <!-- Background gradient orbs -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/20 rounded-full blur-[128px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-accent-500/15 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text Content -->
      <div>
        <!-- Badge -->
        <div class="animate-fade-in-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary-500/30 bg-primary-500/10 text-primary-300 text-sm font-medium mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-400"></span>
          </span>
          Open to Opportunities
        </div>

        <!-- Headline -->
        <h1 class="animate-fade-in-up animate-delay-100 text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight">
          Software Engineer building
          <span class="gradient-text"> AI-powered products.</span>
        </h1>

        <!-- Subheadline -->
        <p class="animate-fade-in-up animate-delay-200 mt-6 text-lg sm:text-xl text-dark-400 leading-relaxed max-w-2xl">
          Full-stack engineer with expertise in <span class="text-dark-200">AI/ML</span>,
          <span class="text-dark-200">backend systems</span>, and
          <span class="text-dark-200">full-stack development</span>.
          Building intelligent products with Django, FastAPI, LangChain, and RAG pipelines.
        </p>

        <!-- CTA Buttons -->
        <div class="animate-fade-in-up animate-delay-300 mt-10 flex flex-wrap gap-4">
          <a
            href="/projects"
            id="hero-view-projects"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl gradient-bg text-white font-semibold text-sm shadow-lg shadow-primary-600/25 hover:shadow-primary-600/40 hover:scale-105 transition-all duration-200"
          >
            View Projects
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/resume.pdf"
            download
            id="hero-download-resume"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-primary-500/40 text-primary-300 font-semibold text-sm hover:bg-primary-500/10 hover:border-primary-500/60 hover:scale-105 transition-all duration-200"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Download Resume
          </a>
          <a
            href="/contact"
            id="hero-contact-me"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-dark-700 text-dark-200 font-semibold text-sm hover:border-primary-500/50 hover:text-white hover:bg-white/5 transition-all duration-200"
          >
            Contact Me
          </a>
        </div>

        <!-- Quick Stats -->
        <div class="animate-fade-in-up animate-delay-400 mt-10 grid grid-cols-3 gap-8 max-w-md">
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">1+</div>
            <div class="text-xs sm:text-sm text-dark-500 mt-1">Years Experience</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">8+</div>
            <div class="text-xs sm:text-sm text-dark-500 mt-1">Products Shipped</div>
          </div>
          <div>
            <div class="text-2xl sm:text-3xl font-bold gradient-text">10+</div>
            <div class="text-xs sm:text-sm text-dark-500 mt-1">Engineers Mentored</div>
          </div>
        </div>
      </div>

      <!-- Right: Profile Image -->
      <div class="animate-fade-in-up animate-delay-300 flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Glow behind image -->
          <div class="absolute inset-0 gradient-bg rounded-3xl blur-2xl opacity-30 scale-95"></div>

          <!-- Image container with gradient border -->
          <div class="relative rounded-3xl p-1 bg-gradient-to-br from-primary-500 via-accent-500 to-primary-600">
            <div class="rounded-[calc(1.5rem-4px)] overflow-hidden">
              <img
                src="/profile.jpg"
                alt="Suhaib Ahmad — Software Engineer"
                width="420"
                height="420"
                class="w-72 h-72 sm:w-80 sm:h-80 lg:w-[420px] lg:h-[420px] object-cover object-top"
                loading="eager"
              />
            </div>
          </div>

          <!-- Decorative accent dot -->
          <div class="absolute -bottom-2 -left-2 w-4 h-4 rounded-full gradient-bg animate-fade-in-up animate-delay-500"></div>
        </div>
      </div>

    </div>
  </div>
</section>
